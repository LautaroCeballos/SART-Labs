---

<section class="section results-section" id="resultados" aria-label="Resultados">
  <!-- Background glow -->
  <div class="results-glow"></div>
  <div class="results-glow-2"></div>

  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Resultados</span>
      <h2 class="text-h2">
        Números que<br />
        <span class="text-gradient">lo dicen todo</span>
      </h2>
      <p class="text-body section-desc">
        Cada proyecto está respaldado por métricas reales. Nuestro objetivo es siempre el mismo: 
        más reservas directas y más rentabilidad para tu complejo.
      </p>
    </div>

    <!-- Stats grid -->
    <div class="results-grid">
      {stats.map((stat, i) => (
        <div
          class={`result-card glass-card reveal reveal-delay-${i + 1}`}
          id={`result-${stat.id}`}
          data-target={stat.value}
          data-suffix={stat.suffix}
          data-prefix={stat.prefix}
        >
          <div class="result-icon" set:html={stat.icon} />
          <div class="result-number">
            <span class="result-prefix">{stat.prefix}</span>
            <span class="counter" data-target={stat.value}>0</span>
            <span class="result-suffix">{stat.suffix}</span>
          </div>
          <h3 class="result-label">{stat.label}</h3>
          <p class="result-desc">{stat.description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom strip -->
    <div class="results-strip reveal">
      <div class="strip-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9l4 4 8-8" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Resultados verificables en los primeros 90 días
      </div>
      <div class="strip-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9l4 4 8-8" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Sin permanencia mínima obligatoria
      </div>
      <div class="strip-item">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9l4 4 8-8" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Reportes mensuales de rendimiento
      </div>
    </div>
  </div>
</section>

<style>
  .results-section {
    position: relative;
    overflow: hidden;
  }

  .results-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    right: -150px;
    top: 0;
    background: radial-gradient(circle, rgba(251,146,60,0.1) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .results-glow-2 {
    position: absolute;
    width: 400px;
    height: 400px;
    left: -100px;
    bottom: 0;
    background: radial-gradient(circle, rgba(160,100,10,0.07) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .result-card {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
    align-items: center;
  }

  .result-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(251, 146, 60, 0.08);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .result-number {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.1rem;
    font-weight: 800;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    line-height: 1;
    background: var(--gradient-blue);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .result-prefix {
    font-size: 0.7em;
  }

  .result-suffix {
    font-size: 0.7em;
  }

  .result-label {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .result-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Bottom strip */
  .results-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    margin-top: 3.5rem;
    padding: 1.25rem 2rem;
    background: rgba(52, 211, 153, 0.05);
    border: 1px solid rgba(52, 211, 153, 0.15);
    border-radius: var(--radius-md);
    position: relative;
    z-index: 1;
  }

  .strip-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  @media (max-width: 1024px) {
    .results-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .results-grid { grid-template-columns: 1fr; }
    .results-strip { gap: 1rem; }
  }
</style>

<script>
  // Counter animation
  const counters = document.querySelectorAll<HTMLElement>(".counter");

  const animateCounter = (el: HTMLElement) => {
    const target = parseInt(el.dataset.target ?? "0", 10);
    const duration = 2000;
    const start = performance.now();

    const update = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = String(Math.floor(eased * target));
      if (progress < 1) requestAnimationFrame(update);
    };

    requestAnimationFrame(update);
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const counter = entry.target as HTMLElement;
          animateCounter(counter);
          observer.unobserve(counter);
        }
      });
    },
    { threshold: 0.5 }
  );

  counters.forEach((c) => observer.observe(c));
</script>
