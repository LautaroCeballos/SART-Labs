---
// Services Section
const services = [
  {
    id: "web-dev",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="8" fill="rgba(251,146,60,0.10)"/><rect x="4" y="6" width="20" height="14" rx="2" stroke="#FB923C" stroke-width="1.5"/><path d="M4 10h20" stroke="#FB923C" stroke-width="1.5"/><path d="M10 22h8" stroke="#FB923C" stroke-width="1.5" stroke-linecap="round"/><path d="M14 19v3" stroke="#FB923C" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Desarrollo Web para Complejos",
    description:
      "Sitios web premium, rápidos y funcionales, diseñados para convertir visitantes en reservas. Estrategia, diseño y desarrollo en un mismo lugar.",
    features: [
      "Diseño personalizado",
      "Carga ultra rápida",
      "SEO optimizado",
      "Checkout simplificado",
    ],
    tag: "Más popular",
  },
  {
    id: "sart-integration",
    icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="8" fill="rgba(251,146,60,0.10)"/><circle cx="14" cy="14" r="6" stroke="#FB923C" stroke-width="1.5"/><path d="M14 8v6l4 2" stroke="#FB923C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M4 14h2M22 14h2M14 4v2M14 22v2" stroke="#FB923C" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    title: "Integración con SART PMS",
    description:
      "Conectamos tu sitio con nuestro sistema de gestión SART para automatizar reservas, disponibilidad y comunicaciones. Todo sincronizado.",
    features: [
      "Calendario en tiempo real",
      "Gestión centralizada",
      "Automatizaciones",
      "Confirmación automática",
    ],
    tag: "Exclusivo",
  },
  // {
  //   id: "conversion",
  //   icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="8" fill="rgba(74,124,89,0.10)"/><path d="M6 20L11 13l4 4 4-5 3 3" stroke="#4A7C59" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="21" cy="8" r="2.5" stroke="#4A7C59" stroke-width="1.5"/></svg>`,
  //   title: "Optimización de Conversión",
  //   description:
  //     "Analizamos el comportamiento de tus visitantes y rediseñamos los flujos críticos para maximizar las reservas directas en tu sitio.",
  //   features: ["Heatmaps y analítica", "A/B testing", "Embudo de reservas"],
  //   tag: null,
  // },
  // {
  //   id: "booking-flow",
  //   icon: `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="8" fill="rgba(74,124,89,0.10)"/><rect x="5" y="5" width="18" height="18" rx="3" stroke="#4A7C59" stroke-width="1.5"/><path d="M5 10h18" stroke="#4A7C59" stroke-width="1.5"/><path d="M10 5v5M18 5v5" stroke="#4A7C59" stroke-width="1.5" stroke-linecap="round"/><path d="M9 15h4M9 18h6" stroke="#4A7C59" stroke-width="1.2" stroke-linecap="round"/></svg>`,
  //   title: "Diseño de Flujo de Reservas",
  //   description:
  //     "Eliminamos la fricción del proceso de reserva. Más pasos claros, más confianza, más conversiones. Sin depender de plataformas externas.",
  //   features: ["Checkout simplificado", "Pagos integrados", "Confirmación automática"],
  //   tag: null,
  // },
];
---

<section class="section" id="servicios" aria-label="Servicios">
  <div class="container">
    <!-- Header -->
    <div class="section-header reveal">
      <span class="section-label">Servicios</span>
      <h2 class="text-h2">
        Todo lo que necesitás para<br />
        <span class="text-gradient">dominar las reservas directas</span>
      </h2>
      <p class="text-body section-desc">
        Desde la estrategia hasta la implementación. Nos especializamos
        exclusivamente en complejos turísticos para darte resultados reales.
      </p>
    </div>

    <!-- Cards -->
    <div class="services-grid">
      {
        services.map((service, i) => (
          <div
            class={`glass-card service-card reveal reveal-delay-${i + 1}`}
            id={`service-${service.id}`}
          >
            {service.tag && <div class="service-tag">{service.tag}</div>}
            <div class="service-icon" set:html={service.icon} />
            <h3 class="text-h3 service-title">{service.title}</h3>
            <p class="text-body service-desc">{service.description}</p>
            <ul class="service-features">
              {service.features.map((f) => (
                <li class="service-feature">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path
                      d="M2 7l3 3 7-6"
                      stroke="#60A5FA"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#contacto" class="service-cta">
              Saber más
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path
                  d="M3 7h8M8 4l3 3-3 3"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 4rem;
  }

  .section-desc {
    margin-top: 1rem;
    font-size: 1rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-tag {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.25rem 0.75rem;
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.32);
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--blue-600);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .service-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-title {
    color: var(--text-primary);
    font-size: 1.15rem;
  }

  .service-desc {
    font-size: 0.9rem;
    flex: 1;
  }

  .service-features {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .service-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--blue-600);
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    transition: var(--transition);
    width: fit-content;
  }

  .service-cta:hover {
    gap: 0.7rem;
    color: var(--blue-500);
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
