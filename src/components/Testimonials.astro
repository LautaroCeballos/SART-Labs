---
// Testimonials Section
const testimonials = [
  {
    id: "vista-sur-testimonial",
    name: "Claudia Fernández",
    role: "Propietaria",
    complex: "Cabañas Vista Sur",
    location: "San Martín de los Andes",
    quote:
      "Desde que lanzamos el sitio nuevo con SART Labs, nuestras reservas directas se triplicaron. Antes dependíamos 100% de Booking. Hoy el 70% de nuestras reservas son directas y sin comisiones. Una transformación total.",
    stars: 5,
    result: "+210% reservas directas",
  },
  {
    id: "rio-claro-testimonial",
    name: "Marcos Gutiérrez",
    role: "Gerente de Operaciones",
    complex: "Complejo Río Claro",
    location: "Villa La Angostura",
    quote:
      "El sistema SART nos cambió la vida. Antes manejábamos todo por WhatsApp y planillas. Ahora tenemos todo centralizado, los pagos automatizados y podemos ver la ocupación en tiempo real. Altamente recomendable.",
    stars: 5,
    result: "Gestión 100% digitalizada",
  },
  {
    id: "patagonia-lodge-testimonial",
    name: "Valeria Torres",
    role: "Directora",
    complex: "Patagonia Lodge Hotel",
    location: "Bariloche",
    quote:
      "Queríamos un sitio que transmitiera la calidad de nuestro hotel. El resultado superó todas las expectativas. El diseño es premium, la velocidad es excelente y nuestros huéspedes comentan que la web fue lo que los convenció de reservar.",
    stars: 5,
    result: "+88% conversión en web",
  },
];
---

<section class="section" id="testimonios" aria-label="Testimonios">
  <div class="container">
    <!-- Header -->
    <div class="section-header reveal">
      <span class="section-label">Testimonios</span>
      <h2 class="text-h2">
        Lo que dicen nuestros<br />
        <span class="text-gradient">clientes</span>
      </h2>
      <p class="text-body section-desc">
        Resultados reales de complejos reales. Sin marketing de humo.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div
          class={`testimonial-card glass-card reveal reveal-delay-${i + 1}`}
          id={t.id}
        >
          <!-- Stars -->
          <div class="stars" aria-label={`${t.stars} estrellas`}>
            {Array.from({ length: t.stars }).map((_, si) => (
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M8 1.5l1.6 3.3 3.6.5-2.6 2.5.6 3.6L8 9.7l-3.2 1.7.6-3.6L2.8 5.3l3.6-.5L8 1.5z" fill="#FBBF24"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="testimonial-quote">
            <span class="quote-mark">"</span>
            {t.quote}
          </blockquote>

          <!-- Result badge -->
          <div class="testimonial-result">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 10l3-4 3 3 3-4 2 2" stroke="#34D399" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {t.result}
          </div>

          <!-- Author -->
          <div class="testimonial-author">
            <div class="author-avatar">
              {t.name.split(" ").map(w => w[0]).join("").slice(0,2)}
            </div>
            <div class="author-info">
              <span class="author-name">{t.name}</span>
              <span class="author-role">{t.role} · {t.complex}</span>
              <span class="author-location">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><path d="M5.5 1a3 3 0 0 1 3 3C8.5 6.5 5.5 10 5.5 10S2.5 6.5 2.5 4a3 3 0 0 1 3-3z" stroke="currentColor" stroke-width="1"/><circle cx="5.5" cy="4" r="1" stroke="currentColor" stroke-width="1"/></svg>
                {t.location}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust footer -->
    <div class="testimonials-trust reveal">
      <div class="trust-item">
        <div class="trust-stars">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M7 1.5l1.4 2.9 3.1.5-2.3 2.2.6 3.1L7 8.6l-2.8 1.6.6-3.1L2.5 4.9l3.1-.5L7 1.5z" fill="#FBBF24"/>
            </svg>
          ))}
        </div>
        <span>4.9/5 puntuación promedio</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1.5l1.6 3.3 3.6.5-2.6 2.5.6 3.6L8 9.7l-3.2 1.7.6-3.6L2.8 5.3l3.6-.5L8 1.5z" fill="#3A7D44"/></svg>
        <span>20+ complejos transformados</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="4" width="12" height="9" rx="1.5" stroke="#3A7D44" stroke-width="1.4"/><path d="M5 4V3a3 3 0 0 1 6 0v1" stroke="#3A7D44" stroke-width="1.4"/></svg>
        <span>100% recomendarían nuestro servicio</span>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .testimonial-card {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .stars {
    display: flex;
    gap: 0.2rem;
  }

  .testimonial-quote {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-style: normal;
    position: relative;
    flex: 1;
  }

  .quote-mark {
    font-size: 4rem;
    line-height: 0;
    vertical-align: -1rem;
    color: rgba(105,181,120,0.2);
    font-family: Georgia, serif;
    margin-right: 0.1rem;
  }

  .testimonial-result {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    background: rgba(251, 146, 60, 0.08);
    border: 1px solid rgba(251, 146, 60, 0.25);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--green-dark);
    width: fit-content;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(105,181,120,0.2), rgba(37,77,50,0.12));
    border: 1px solid rgba(105,181,120,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--green-dark);
    flex-shrink: 0;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .author-role {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .author-location {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }

  /* Trust footer */
  .testimonials-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding: 1.25rem 2rem;
    background: rgba(255, 252, 248, 0.92);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 12px rgba(37,77,50,0.06);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .trust-stars {
    display: flex;
    gap: 0.15rem;
  }

  .trust-divider {
    width: 1px;
    height: 24px;
    background: var(--border);
  }

  @media (max-width: 1024px) {
    .testimonials-grid { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; }
  }

  @media (max-width: 600px) {
    .trust-divider { display: none; }
    .testimonials-trust { flex-direction: column; gap: 0.75rem; }
  }
</style>

