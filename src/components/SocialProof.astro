---
// Social Proof Section
const clients = [
  "Cabañas El Pinar",
  "Hostería Las Piedras",
  "Complejo Rio Claro",
  "Resort Los Alamos",
  "Cabañas Vista Sur",
  "Hotel Patagonia Lodge",
  "Complejo El Molino",
  "Spa & Cabins Lacar",
  "Cabañas El Pinar",
  "Hostería Las Piedras",
  "Complejo Rio Claro",
  "Resort Los Alamos",
  "Cabañas Vista Sur",
  "Hotel Patagonia Lodge",
  "Complejo El Molino",
  "Spa & Cabins Lacar",
];
---

<section class="social-proof section-sm" id="clientes" aria-label="Clientes">
  <div class="container">
    <p class="proof-label reveal">
      Complejos que ya aumentaron sus reservas directas con nosotros
    </p>
  </div>

  <div class="marquee-wrapper reveal reveal-delay-1">
    <div class="marquee-track">
      {clients.map((name, i) => (
        <div class="client-pill">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect width="18" height="18" rx="5" fill="rgba(251,146,60,0.12)"/>
            <path d="M5 9l2.5 2.5L13 6" stroke="#7C2D12" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>{name}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="proof-bottom reveal reveal-delay-2">
    <div class="proof-stat">
      <span class="proof-number">20+</span>
      <span class="proof-desc">complejos activos</span>
    </div>
    <div class="proof-divider"></div>
    <div class="proof-stat">
      <span class="proof-number">98%</span>
      <span class="proof-desc">clientes satisfechos</span>
    </div>
    <div class="proof-divider"></div>
    <div class="proof-stat">
      <span class="proof-number">3 años</span>
      <span class="proof-desc">de experiencia en el sector</span>
    </div>
  </div>
</section>

<div class="section-divider"></div>

<style>
  .social-proof {
    padding-bottom: 3rem;
  }

  .proof-label {
    text-align: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .client-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.25rem;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(124, 45, 18, 0.18);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
    transition: var(--transition);
    box-shadow: 0 2px 8px rgba(100, 60, 0, 0.07);
    flex-shrink: 0;
  }

  .client-pill:hover {
    border-color: rgba(124, 45, 18, 0.32);
    color: var(--text-primary);
    box-shadow: 0 4px 16px rgba(251, 146, 60, 0.12);
    transform: translateY(-1px);
  }

  .proof-bottom {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    margin-top: 3rem;
    flex-wrap: wrap;
  }

  .proof-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .proof-number {
    font-size: 1.8rem;
    font-weight: 800;
    background: var(--gradient-blue);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .proof-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 600;
  }

  .proof-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  @media (max-width: 600px) {
    .proof-divider { display: none; }
    .proof-bottom { gap: 1.5rem; flex-direction: column; }
  }
</style>
