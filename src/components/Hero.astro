---
// Hero Section
---

<section class="hero" id="hero" aria-label="Inicio">
  <!-- Background elements -->
  <div class="hero-bg">
    <div class="glow-orb glow-orb-blue hero-orb-1"></div>
    <div class="glow-orb glow-orb-indigo hero-orb-2"></div>
    <div class="hero-grid-overlay"></div>
  </div>

  <div class="container hero-content">
    <!-- Left column -->
    <div class="hero-text">
      <div class="hero-badge reveal">
        <span class="badge-dot"></span>
        Agencia especializada en complejos turísticos
      </div>

      <h1 class="text-display hero-headline reveal reveal-delay-1">
        Tu complejo merece<br />
        <span class="text-gradient">más reservas directas</span><br />
        y menos comisiones
      </h1>

      <p class="text-body hero-subtitle reveal reveal-delay-2">
        Diseñamos sitios web de alta conversión para cabañas, hoteles y resorts. 
        Eliminá la dependencia de plataformas y transformá tu web en tu mejor canal de ventas.
      </p>

      <!-- Stats row -->
      <div class="hero-stats reveal reveal-delay-3">
        <div class="hero-stat">
          <span class="hero-stat-number">+68%</span>
          <span class="hero-stat-label">Reservas directas</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number">-40%</span>
          <span class="hero-stat-label">Comisiones externas</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number">20+</span>
          <span class="hero-stat-label">Complejos activos</span>
        </div>
      </div>

      <!-- CTAs -->
      <div class="hero-ctas reveal reveal-delay-4">
        <a href="#portfolio" class="btn btn-primary btn-lg" id="hero-cta-projects">
          <span>Ver proyectos</span>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9h10M10 5l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#contacto" class="btn btn-ghost btn-lg" id="hero-cta-meeting">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M6 2v4M12 2v4M2 9h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          <span>Agendar reunión</span>
        </a>
      </div>
    </div>

    <!-- Right column — mockup card -->
    <div class="hero-visual reveal reveal-delay-2">
      <div class="hero-mockup">
        <!-- Browser chrome -->
        <div class="mockup-chrome">
          <div class="chrome-dots">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
          </div>
          <div class="chrome-url">sartlabs.com.ar/tu-complejo</div>
        </div>

        <!-- Dashboard preview -->
        <div class="mockup-body">
          <!-- Mini header -->
          <div class="mock-header">
            <div class="mock-nav-items">
              <span class="mock-nav active">Inicio</span>
              <span class="mock-nav">Cabañas</span>
              <span class="mock-nav">Reservar</span>
            </div>
            <div class="mock-book-btn">Reservar ahora</div>
          </div>

          <!-- Hero preview -->
          <div class="mock-hero-area">
            <div class="mock-hero-text">
              <div class="mock-badge">Oferta directa</div>
              <div class="mock-title">Complejo Vista Sur</div>
              <div class="mock-subtitle">Reservás directo, pagás menos</div>
              <div class="mock-cta-row">
                <div class="mock-cta">Ver disponibilidad</div>
                <div class="mock-price"><span>$85.000</span> / noche</div>
              </div>
            </div>
            <div class="mock-photo-placeholder">
              <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="rgba(251,146,60,0.1)"/><path d="M8 30l8-8 6 6 4-4 6 6" stroke="rgba(251,146,60,0.6)" stroke-width="1.5" stroke-linecap="round"/><circle cx="14" cy="14" r="4" stroke="rgba(251,146,60,0.6)" stroke-width="1.5"/></svg>
            </div>
          </div>

          <!-- Stats row in mockup -->
          <div class="mock-stats-row">
            <div class="mock-stat">
              <span class="mock-stat-value">+68%</span>
              <span class="mock-stat-lb">Conversión</span>
            </div>
            <div class="mock-stat">
              <span class="mock-stat-value">4.9★</span>
              <span class="mock-stat-lb">Rating</span>
            </div>
            <div class="mock-stat">
              <span class="mock-stat-value">SART</span>
              <span class="mock-stat-lb">Integrado</span>
            </div>
          </div>
        </div>

        <!-- Floating badges -->
        <div class="float-badge float-badge-1 reveal reveal-delay-3">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2l1.8 3.6L14 6.2l-3 2.9.7 4.1L8 11.1l-3.7 2.1.7-4.1L2 6.2l4.2-.6L8 2z" fill="#FBBF24"/></svg>
          Nueva reserva confirmada
        </div>
        <div class="float-badge float-badge-2 reveal reveal-delay-4">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l3.5 3.5L12 3" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Sin comisiones de Booking
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll-indicator">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
  }

  /* Background */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-orb-1 {
    width: 700px;
    height: 700px;
    top: -200px;
    left: -100px;
    opacity: 0.5;
  }

  .hero-orb-2 {
    width: 500px;
    height: 500px;
    bottom: -100px;
    right: -100px;
    opacity: 0.35;
  }

  .hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(251,146,60,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(251,146,60,0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 40%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 40%, transparent 100%);
  }

  /* Content layout */
  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  /* Left: text */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    background: rgba(251, 146, 60, 0.12);
    border: 1px solid rgba(251, 146, 60, 0.28);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--blue-600);
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: #34D399;
    border-radius: 50%;
    box-shadow: 0 0 8px #34D399;
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-headline {
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    max-width: 500px;
    margin-bottom: 2rem;
  }

  /* Stats row */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    padding: 1rem 1.5rem;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    box-shadow: 0 2px 16px rgba(124,45,18,0.08);
    width: fit-content;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .hero-stat-number {
    font-size: 1.4rem;
    font-weight: 800;
    background: var(--gradient-blue);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .hero-stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 500;
    white-space: nowrap;
  }

  .hero-stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Right: mockup */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .hero-mockup {
    position: relative;
    width: 100%;
    max-width: 480px;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(20px);
    box-shadow: var(--shadow-float), 0 0 40px rgba(251,146,60,0.1);
    overflow: visible;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* Chrome top bar */
  .mockup-chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .chrome-dots { display: flex; gap: 0.35rem; }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot-red    { background: #FF5F57; }
  .dot-yellow { background: #FEBC2E; }
  .dot-green  { background: #28C840; }

  .chrome-url {
    flex: 1;
    padding: 0.3rem 0.75rem;
    background: rgba(251,146,60,0.05);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: center;
  }

  /* Mockup body */
  .mockup-body { padding: 0; overflow: hidden; border-radius: 0 0 var(--radius-xl) var(--radius-xl); }

  .mock-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .mock-nav-items { display: flex; gap: 0.75rem; }
  .mock-nav {
    font-size: 0.72rem;
    color: var(--text-muted);
    padding: 0.25rem 0;
    font-weight: 500;
  }
  .mock-nav.active {
    color: var(--blue-600);
    border-bottom: 1px solid var(--blue-600);
  }

  .mock-book-btn {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    background: var(--gradient-blue);
    border-radius: 6px;
    color: white;
    box-shadow: 0 2px 8px rgba(251, 146, 60, 0.25);
  }

  .mock-hero-area {
    display: flex;
    align-items: stretch;
    gap: 1rem;
    padding: 1rem;
    background: linear-gradient(135deg, rgba(251,146,60,0.05) 0%, transparent 100%);
    min-height: 120px;
  }

  .mock-hero-text { flex: 1; }

  .mock-badge {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    background: rgba(52, 211, 153, 0.15);
    color: #34D399;
    border-radius: 4px;
    margin-bottom: 0.4rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .mock-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .mock-subtitle {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }

  .mock-cta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mock-cta {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.35rem 0.85rem;
    background: var(--gradient-blue);
    border-radius: 5px;
    color: white;
    box-shadow: 0 2px 8px rgba(251, 146, 60, 0.2);
  }

  .mock-price {
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .mock-price span {
    color: var(--text-primary);
    font-weight: 700;
  }

  .mock-photo-placeholder {
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(251,146,60,0.06);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    flex-shrink: 0;
  }

  .mock-stats-row {
    display: flex;
    border-top: 1px solid var(--border);
    padding: 0.75rem 1rem;
    gap: 1rem;
  }

  .mock-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .mock-stat-value {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--blue-600);
    line-height: 1;
  }

  .mock-stat-lb {
    font-size: 0.63rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  /* Floating badges */
  .float-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: rgba(255, 255, 255, 0.97);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-primary);
    backdrop-filter: blur(12px);
    white-space: nowrap;
    box-shadow: var(--shadow-card);
  }

  .float-badge-1 {
    top: -16px;
    right: -16px;
    animation: float-badge-1 5s ease-in-out infinite;
  }

  .float-badge-2 {
    bottom: -16px;
    left: -16px;
    animation: float-badge-2 5s ease-in-out 1s infinite;
  }

  @keyframes float-badge-1 {
    0%, 100% { transform: translateY(0) rotate(1deg); }
    50% { transform: translateY(-8px) rotate(-1deg); }
  }

  @keyframes float-badge-2 {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(-6px) rotate(1deg); }
  }

  /* Scroll indicator */
  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
  }

  .scroll-mouse {
    width: 22px;
    height: 36px;
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 11px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .scroll-wheel {
    width: 3px;
    height: 8px;
    background: var(--blue-500);
    border-radius: 2px;
    animation: scroll-anim 2s ease-in-out infinite;
  }

  @keyframes scroll-anim {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(12px); opacity: 0; }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-badge { margin: 0 auto 1.5rem; }
    .hero-subtitle { margin: 0 auto 2rem; }
    .hero-stats { margin: 0 auto 2rem; }
    .hero-ctas { justify-content: center; }
    .hero-visual { order: -1; }
    .hero-mockup { max-width: 360px; }
  }

  @media (max-width: 480px) {
    .hero-stats { gap: 1rem; padding: 0.75rem 1rem; }
    .hero-stat-number { font-size: 1.1rem; }
    .float-badge-1 { top: -10px; right: 0; }
    .float-badge-2 { bottom: -10px; left: 0; }
  }
</style>
